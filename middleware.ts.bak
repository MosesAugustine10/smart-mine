import { createServerClient } from "@supabase/ssr"
import { NextResponse, type NextRequest } from "next/server"

export async function middleware(request: NextRequest) {
  const { pathname } = request.nextUrl
  console.log(`[MIDDLEWARE] Accessing: ${pathname}`)

  const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL
  const supabaseKey = process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY

  // 1. PUBLIC ROUTES - Always fast path
  if (pathname === '/' || pathname.startsWith('/auth') || pathname.startsWith('/api') || pathname.startsWith('/landing')) {
    return NextResponse.next()
  }

  // 2. DEMO MODE OR MISSING CONFIG - Bypass auth layer for stability
  const demoCookie = request.cookies.get('demo_token')
  if (demoCookie || !supabaseUrl || !supabaseKey || supabaseUrl.includes('demo-project.supabase.co')) {
    console.log(`[MIDDLEWARE] Demo/Bypass mode active for: ${pathname}`)
    return NextResponse.next()
  }

  // STEP 2: Real Supabase auth check for production users
  let supabaseResponse = NextResponse.next({ request })

  const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL
  const supabaseKey = process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY

  // If Supabase env vars are not configured, allow access rather than locking users out.
  // This prevents the redirect loop when running in a misconfigured or offline environment.
  if (!supabaseUrl || !supabaseKey || supabaseUrl.includes('demo-project.supabase.co')) {
    return NextResponse.next()
  }

  const supabase = createServerClient(
    supabaseUrl,
    supabaseKey,
    {
      cookies: {
        getAll() {
          return request.cookies.getAll()
        },
        setAll(cookiesToSet) {
          cookiesToSet.forEach(({ name, value }) => request.cookies.set(name, value))
          supabaseResponse = NextResponse.next({ request })
          cookiesToSet.forEach(({ name, value, options }) =>
            supabaseResponse.cookies.set(name, value, options)
          )
        },
      },
    }
  )

  let user = null
  try {
    const { data, error } = await supabase.auth.getUser()
    // Only set user if there is no error - avoids false logouts on network issues
    if (!error) {
      user = data.user
    }
  } catch (e) {
    // On Supabase error (network timeout, config issue), do NOT redirect to login.
    // This is the key fix: a failed auth check should not kick users out.
    console.error("Supabase middleware auth error (non-fatal):", e)
    return NextResponse.next()
  }

  // Only redirect to login if we are CERTAIN the user is not authenticated
  if (!user) {
    const url = request.nextUrl.clone()
    url.pathname = "/auth/login"
    return NextResponse.redirect(url)
  }

  return supabaseResponse
}

